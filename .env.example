# Vision Service Configuration

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Model settings
MODEL_DEVICE=cpu
YOLO_MODEL_PATH=./models/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# OCR settings
OCR_LANGUAGES=["ch_sim","en"]
OCR_GPU=false

# Image Analysis settings
# Set to "local" to use local LLaVA model, or "api" to use external API
ANALYSIS_MODE=api
LLAVA_API_URL=
LLAVA_API_KEY=

# Temp files
TEMP_DIR=./temp
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO
